{
  "name": "@ariadocs/react",
  "version": "2.1.0",
  "type": "module",
  "author": {
    "name": "Nisab Mohd",
    "email": "nisabmohd@gmail.com"
  },
  "license": "MIT",
  "description": "A documentation-building library for React and Next.js. Render MDX content, organize docs, and build modern documentation sites.",
  "keywords": [
    "react",
    "nextjs",
    "mdx",
    "documentation",
    "docs",
    "markdown"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/components/client.d.ts",
      "default": "./dist/components/client.js"
    },
    "./server": {
      "types": "./dist/components/server.d.ts",
      "default": "./dist/components/server.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "default": "./dist/plugins.js"
    },
    "./nav": {
      "types": "./dist/nav.d.ts",
      "default": "./dist/nav.js"
    },
    "./parse": {
      "types": "./dist/parse.d.ts",
      "default": "./dist/parse.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./syntax.css": {
      "default": "./dist/styles/syntax.css"
    },
    "./styles/github.css": {
      "default": "./dist/styles/github.css"
    },
    "./styles/nord.css": {
      "default": "./dist/styles/nord.css"
    },
    "./styles/minimal.css": {
      "default": "./dist/styles/minimal.css"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warncd ings 0",
    "build": "tsc && copyfiles -u 1 \"src/styles/**/*.css\" dist"
  },
  "packageManager": "pnpm@10.4.1",
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next-mdx-remote-client": "^2.1.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.0",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-flexible-toc": "^1.2.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "copyfiles": "^2.4.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nisabmohd/Aria-Docs.git",
    "directory": "packages/library"
  },
  "bugs": {
    "url": "https://github.com/nisabmohd/Aria-Docs/issues"
  },
  "homepage": "https://github.com/nisabmohd/Aria-Docs#readme"
}